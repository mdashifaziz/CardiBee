# CardiBee Flutter — dart-define keys
# Pass these at build/run time:
#   flutter run --dart-define=USE_MOCK_API=true --dart-define=ENV=dev
#
# Or create a .env file and pass via:
#   flutter run --dart-define-from-file=.env

# Toggle mock repositories (true = no network calls)
USE_MOCK_API=true

# Deployment environment: dev | staging | prod
ENV=dev

# API base URL overrides (optional — defaults are baked into env.dart)
# API_BASE_URL=https://api-dev.cardibee.com.bd/v1

# Firebase (only needed for push notifications in dev — use google-services.json for prod)
# FIREBASE_PROJECT_ID=cardibee-dev
